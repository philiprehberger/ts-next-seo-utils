{
  "name": "@philiprehberger/next-seo-utils",
  "version": "0.1.4",
  "description": "Next.js SEO utilities: metadata generators, JSON-LD schemas, and Open Graph helpers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test src/__tests__/index.test.mjs"
  },
  "keywords": ["next.js", "seo", "metadata", "json-ld", "open-graph", "structured-data"],
  "author": "Philip Rehberger",
  "license": "MIT",
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "next": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": { "type": "git", "url": "git+https://github.com/philiprehberger/ts-next-seo-utils.git" },
  "homepage": "https://github.com/philiprehberger/ts-next-seo-utils#readme",
  "bugs": { "url": "https://github.com/philiprehberger/ts-next-seo-utils/issues" },
  "engines": { "node": ">=18.0.0" }
}
